/* ── Reset & Base ────────────────────────────────────────── */
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 11pt;
  line-height: 1.6;
  color: #1e293b;
  background: #ffffff;
}

/* ── Cover Page ─────────────────────────────────────────── */
.cover-page {
  page-break-after: always;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1a365d 100%);
  color: #ffffff;
  padding: 40mm 30mm;
}

.cover-logo {
  width: 80px;
  height: 80px;
  border: 3px solid rgba(255,255,255,0.3);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 32px;
  background: rgba(255,255,255,0.1);
}

.cover-company {
  font-size: 14pt;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 16px;
}

.cover-title {
  font-size: 32pt;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 12px;
}

.cover-subtitle {
  font-size: 16pt;
  font-weight: 300;
  color: #cbd5e1;
  margin-bottom: 48px;
}

.cover-meta {
  display: flex;
  gap: 32px;
  margin-top: 24px;
}

.cover-meta-item {
  text-align: center;
}

.cover-meta-label {
  font-size: 9pt;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #94a3b8;
  margin-bottom: 4px;
}

.cover-meta-value {
  font-size: 11pt;
  font-weight: 500;
  color: #e2e8f0;
}

.cover-divider {
  width: 60px;
  height: 2px;
  background: #3b82f6;
  margin: 24px auto;
}

/* ── TOC Page ───────────────────────────────────────────── */
.toc-page {
  page-break-after: always;
  padding-top: 8mm;
}

.toc-page h2 {
  font-size: 18pt;
  color: #1e3a5f;
  border-bottom: 2px solid #1e3a5f;
  padding-bottom: 8px;
  margin-bottom: 24px;
}

.toc-list {
  list-style: none;
}

.toc-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 4px 0;
  border-bottom: 1px dotted #e2e8f0;
}

.toc-item a {
  text-decoration: none;
  color: #1e3a5f;
  font-weight: 500;
  font-size: 11pt;
}

.toc-item a:hover {
  color: #3b82f6;
}

.toc-item .toc-count {
  font-size: 9pt;
  color: #64748b;
  flex-shrink: 0;
  margin-left: 8px;
}

.toc-sub {
  list-style: none;
  padding-left: 20px;
  margin-top: 2px;
}

.toc-sub .toc-item {
  border-bottom: none;
  padding: 2px 0;
}

.toc-sub .toc-item a {
  font-weight: 400;
  font-size: 10pt;
  color: #475569;
}

/* ── Tag Sections ───────────────────────────────────────── */
.tag-section {
  page-break-before: always;
  padding-top: 4mm;
}

.tag-section:first-of-type {
  page-break-before: auto;
}

.tag-header {
  font-size: 18pt;
  color: #1e3a5f;
  border-bottom: 2px solid #1e3a5f;
  padding-bottom: 8px;
  margin-bottom: 24px;
}

.tag-description {
  font-size: 10pt;
  color: #64748b;
  margin-top: -18px;
  margin-bottom: 20px;
}

/* ── Endpoint Block ─────────────────────────────────────── */
.endpoint {
  margin-bottom: 28px;
  page-break-inside: avoid;
}

.endpoint-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 6px 6px 0 0;
  border: 1px solid #e2e8f0;
  border-bottom: none;
  background: #f8fafc;
}

.method-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 4px;
  font-size: 9pt;
  font-weight: 700;
  letter-spacing: 0.5px;
  color: #ffffff;
  min-width: 56px;
  text-align: center;
}

.method-GET    { background: #22c55e; }
.method-POST   { background: #3b82f6; }
.method-PUT    { background: #f59e0b; }
.method-PATCH  { background: #eab308; }
.method-DELETE { background: #ef4444; }

.endpoint-path {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 10pt;
  color: #1e293b;
  font-weight: 500;
}

.endpoint-summary {
  font-size: 10pt;
  color: #64748b;
  margin-left: auto;
  text-align: right;
  max-width: 50%;
}

.endpoint-body {
  border: 1px solid #e2e8f0;
  border-radius: 0 0 6px 6px;
  padding: 14px;
  background: #ffffff;
}

.endpoint-body.deprecated {
  opacity: 0.6;
  background: #fef9c3;
}

.endpoint-description {
  font-size: 10pt;
  color: #475569;
  margin-bottom: 12px;
  line-height: 1.5;
}

/* ── Tables ─────────────────────────────────────────────── */
.param-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 9pt;
  margin: 8px 0 16px 0;
}

.param-table th {
  background: #1e3a5f;
  color: #ffffff;
  padding: 6px 10px;
  text-align: left;
  font-weight: 600;
  font-size: 8.5pt;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.param-table td {
  padding: 5px 10px;
  border-bottom: 1px solid #f1f5f9;
  vertical-align: top;
}

.param-table tr:nth-child(even) td {
  background: #f8fafc;
}

.param-name {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 9pt;
  color: #1e3a5f;
  font-weight: 500;
}

.param-type {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 8.5pt;
  color: #6366f1;
  background: #eef2ff;
  padding: 1px 5px;
  border-radius: 3px;
}

.param-required {
  font-size: 7.5pt;
  color: #ef4444;
  font-weight: 600;
}

.param-nullable {
  font-size: 7.5pt;
  color: #94a3b8;
}

.param-nested {
  padding-left: 18px;
  border-left: 2px solid #e2e8f0;
}

/* ── Section Labels ─────────────────────────────────────── */
.section-label {
  font-size: 9pt;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #1e3a5f;
  margin: 16px 0 6px 0;
  padding-bottom: 4px;
  border-bottom: 1px solid #e2e8f0;
}

/* ── Response Code Badges ───────────────────────────────── */
.status-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 3px;
  font-size: 8.5pt;
  font-weight: 700;
  font-family: 'SF Mono', 'Consolas', monospace;
}

.status-2xx { background: #dcfce7; color: #166534; }
.status-3xx { background: #dbeafe; color: #1e40af; }
.status-4xx { background: #fef9c3; color: #854d0e; }
.status-5xx { background: #fee2e2; color: #991b1b; }

/* ── Schema Reference Section ───────────────────────────── */
.schema-section {
  page-break-before: always;
}

.schema-section h2 {
  font-size: 18pt;
  color: #1e3a5f;
  border-bottom: 2px solid #1e3a5f;
  padding-bottom: 8px;
  margin-bottom: 24px;
}

.schema-block {
  margin-bottom: 20px;
  page-break-inside: avoid;
}

.schema-name {
  font-size: 12pt;
  font-weight: 700;
  color: #1e3a5f;
  margin-bottom: 4px;
}

.schema-description {
  font-size: 9pt;
  color: #64748b;
  margin-bottom: 8px;
}

/* ── Print Tweaks ───────────────────────────────────────── */
@media print {
  body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

  .cover-page {
    height: auto;
    min-height: 100vh;
  }

  .endpoint {
    page-break-inside: avoid;
  }

  .tag-section {
    page-break-before: always;
  }

  .tag-section:first-of-type {
    page-break-before: avoid;
  }
}
