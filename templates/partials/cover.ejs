<!-- Cover Page -->
<div class="cover-page">
  <div class="cover-logo">API</div>
  <div class="cover-company"><%- esc(company) %></div>
  <div class="cover-divider"></div>
  <h1 class="cover-title"><%- esc(project) %></h1>
  <% if (project !== 'API Documentation') { %>
    <p class="cover-subtitle">API Documentation</p>
  <% } %>
  <div class="cover-meta">
    <div class="cover-meta-item">
      <div class="cover-meta-label">Version</div>
      <div class="cover-meta-value"><%- esc(specs[0]?.version || '1.0.0') %></div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Base URL</div>
      <div class="cover-meta-value"><%- esc(baseUrl) %></div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Auth</div>
      <div class="cover-meta-value"><%- esc(authType) %></div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Date</div>
      <div class="cover-meta-value"><%- esc(date) %></div>
    </div>
  </div>
</div>
